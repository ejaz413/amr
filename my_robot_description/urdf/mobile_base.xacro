<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mobile_base">

  <!-- Base geometry (edit if your real chassis is different) -->
  <xacro:property name="base_length" value="0.6" />
  <xacro:property name="base_width"  value="0.45" />
  <xacro:property name="base_height" value="0.2" />

  <!-- REAL HARDWARE VALUES -->
  <xacro:property name="wheel_radius"     value="0.07490" />
  <xacro:property name="wheel_separation" value="0.512" />

  <!-- Visual wheel thickness (does not affect kinematics) -->
  <xacro:property name="wheel_length" value="0.05" />

  <!-- Frames -->
  <link name="base_footprint" />

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}" />
      </geometry>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0" />
      <material name="blue" />
    </visual>
  </link>

  <!-- Wheel link macro -->
  <xacro:macro name="wheel_link" params="prefix">
    <link name="${prefix}_wheel_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}" />
        </geometry>
        <!-- Cylinder axis is Z by default; rotate so it spins about Y -->
        <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
        <material name="grey" />
      </visual>
    </link>
  </xacro:macro>

  <xacro:wheel_link prefix="right" />
  <xacro:wheel_link prefix="left" />

  <!-- Simple caster (visual only) -->
  <link name="caster_wheel_link">
    <visual>
      <geometry>
        <sphere radius="${wheel_radius / 2.0}" />
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <material name="grey" />
    </visual>
  </link>

  <!-- base_footprint -> base_link at wheel radius height -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0" />
  </joint>

  <!-- Wheels placed at +/- wheel_separation/2 -->
  <joint name="base_right_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="right_wheel_link" />
    <origin xyz="${-base_length / 4.0} ${-wheel_separation / 2.0} 0" rpy="0 0 0" />
    <axis xyz="0 1 0" />
  </joint>

  <joint name="base_left_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="left_wheel_link" />
    <origin xyz="${-base_length / 4.0} ${wheel_separation / 2.0} 0" rpy="0 0 0" />
    <axis xyz="0 1 0" />
  </joint>

  <!-- Caster location (visual only) -->
  <joint name="base_caster_wheel_joint" type="fixed">
    <parent link="base_link" />
    <child link="caster_wheel_link" />
    <origin xyz="${base_length / 3.0} 0 ${-wheel_radius / 2.0}" rpy="0 0 0" />
  </joint>

</robot>
